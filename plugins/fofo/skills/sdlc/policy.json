{
  "_comment": "Default gate behavior. Sane, strict-but-runnable defaults. Edit per-gate options under 'gates'. Thresholds and banned patterns live here; orchestration (enabled/tier/command/endpoint) lives in gates.config.",

  "gates": {
    "spec-lint": {
      "spec_file": "REQUIREMENTS.md",
      "id_pattern": "REQ-\\d+",
      "acceptance_label": "Acceptance",
      "accept_ears": true
    },
    "trace-gate": {
      "spec_file": "REQUIREMENTS.md",
      "id_pattern": "REQ-\\d+",
      "test_reqs": "TEST-REQS.yaml"
    },
    "redgreen-gate": {
      "test_command": null,
      "timeout_seconds": 600
    },
    "flake-gate": {
      "test_command": null,
      "runs": 3,
      "timeout_seconds": 600
    },
    "diff-budget": {
      "max_lines": 400,
      "base_ref": "HEAD",
      "count_mode": "auto",
      "on_exceed": "escalate"
    },
    "intent-gate": {
      "test_launchers": ["it", "test", "fit", "xit", "specify"],
      "assertion_roots": ["should"],
      "banned_mocks": [],
      "allow_snapshot_only": false,
      "fail_on": ["assertion-free", "trivial"]
    },
    "secret-scan": {
      "min_token_length": 16,
      "allowlist": [],
      "fail_on": ["high"]
    },
    "separation-gate": {
      "manifest": null
    },
    "test-lock": {
      "lock_file": "TEST-LOCK.json",
      "test_glob": null
    },
    "oversight-integrity": {
      "protected": null,
      "extra_protected": [],
      "base_ref": "HEAD",
      "on_touch": "fail"
    },
    "deps-gate": {
      "manifests": null,
      "base_ref": "HEAD",
      "on_new": "escalate"
    },
    "semantic-test-judge": {
      "spec_file": "REQUIREMENTS.md",
      "escalate_below": 0.6
    },
    "fresh-eyes-review": {
      "spec_file": "REQUIREMENTS.md"
    }
  }
}
