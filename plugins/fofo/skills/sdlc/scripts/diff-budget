#!/usr/bin/env python3
"""
diff-budget — Phase 7 exit gate (language-agnostic).

Keeps a change reviewable by capping how much it touches. A diff a human can't
hold in their head doesn't get a real review — it gets a rubber stamp, which is
exactly the trust failure the rest of this loop exists to prevent. So "is this
small enough to actually review?" is a script with an exit code, not a hope.

Counts changed lines two ways, auto-selected:
  - git mode  : `git diff --numstat <base_ref>` summed (added + deleted), restricted
                to the --changed paths when any are given. Used when --context is a
                git work tree and the base ref resolves.
  - lines mode: total line count of the --changed files. Fallback when there is no
                git repo (e.g. a freshly unpacked tree). Honest about being a coarser
                proxy — it counts size, not delta.

Over budget -> escalate by default (a human decides if the big change is justified;
waivable in gates.config so it informs rather than blocks). Under -> pass. Nothing
to measure -> skip.

Contract: see references/gate-contract.md
Config keys (policy.gates.diff-budget):
  max_lines     budget for added+deleted lines        (default 400)
  base_ref      git ref to diff against               (default "HEAD")
  count_mode    "auto" | "git" | "lines"              (default "auto")
  on_exceed     "escalate" | "fail"                   (default "escalate")
"""
import os
import subprocess
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import gatelib  # noqa: E402

GATE, TIER = "diff-budget", 0


def is_git_repo(root):
    try:
        proc = subprocess.run(["git", "rev-parse", "--is-inside-work-tree"],
                              cwd=root, capture_output=True, text=True)
        return proc.returncode == 0 and proc.stdout.strip() == "true"
    except (OSError, FileNotFoundError):
        return False


def git_diff_lines(root, base_ref, paths):
    """Return (added+deleted) line count from numstat, or None if git can't answer."""
    cmd = ["git", "diff", "--numstat", base_ref]
    if paths:
        cmd += ["--"] + paths
    try:
        proc = subprocess.run(cmd, cwd=root, capture_output=True, text=True)
    except (OSError, FileNotFoundError):
        return None
    if proc.returncode != 0:
        return None
    return sum_numstat(proc.stdout)


def sum_numstat(text):
    """Sum added+deleted across `git diff --numstat` output. Binary files (-) skip.

    Pure: unit-testable without a repo.
    """
    total = 0
    for line in text.splitlines():
        parts = line.split("\t")
        if len(parts) < 2:
            continue
        added, deleted = parts[0], parts[1]
        if added == "-" or deleted == "-":  # binary file
            continue
        try:
            total += int(added) + int(deleted)
        except ValueError:
            continue
    return total


def count_file_lines(files):
    """Total line count of the given files (the lines-mode fallback)."""
    total = 0
    for f in files:
        text = gatelib.read_text(f)
        if text:
            total += text.count("\n") + (0 if text.endswith("\n") else 1)
    return total


def main():
    _p, args = gatelib.parse_args()
    policy = gatelib.load_policy(args)
    opts = gatelib.gate_options(policy, GATE)
    root = args.context or "."

    max_lines = int(opts.get("max_lines", 400))
    base_ref = opts.get("base_ref", "HEAD")
    count_mode = opts.get("count_mode", "auto")
    on_exceed = opts.get("on_exceed", "escalate")
    if on_exceed not in ("escalate", "fail"):
        on_exceed = "escalate"

    paths = gatelib.split_patterns(args.changed)
    files = gatelib.expand_changed(args.changed, root)

    use_git = count_mode == "git" or (count_mode == "auto" and is_git_repo(root))
    total, mode = None, None
    if use_git:
        total = git_diff_lines(root, base_ref, paths)
        if total is not None:
            mode = "git"
    if total is None:
        if not files:
            gatelib.emit(GATE, TIER, "skip", "nothing to measure (no git diff and no --changed files)")
        total = count_file_lines(files)
        mode = "lines"

    detail = "%d changed line(s) via %s mode vs budget %d" % (total, mode, max_lines)
    if total > max_lines:
        gatelib.emit(GATE, TIER, on_exceed,
                     "diff over budget: %s" % detail,
                     [gatelib.finding("med", "%s mode" % mode,
                      "Change touches %d lines (budget %d). Split it so a reviewer can actually hold it." % (
                          total, max_lines))],
                     confidence=1.0)
    gatelib.emit(GATE, TIER, "pass", "diff within budget: %s" % detail, confidence=1.0)


if __name__ == "__main__":
    try:
        main()
    except Exception as exc:  # noqa: BLE001
        gatelib.fail_internal(GATE, TIER, exc)
