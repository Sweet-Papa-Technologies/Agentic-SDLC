#!/usr/bin/env python3
"""
secret-scan — deterministic hard-coded-secret detector (Tier 0, language-agnostic).

Scans the files named in --changed for credential material using deterministic
patterns. No network, no third-party deps — runs on a fresh install. This is the
always-on, key-free complement to the model-based `fresh-eyes-review`: it catches
the most dangerous leaks (live keys, private keys) before they reach a diff.

What it flags:
  high — unambiguous secrets: AWS access key ids (AKIA + 16 alnum) and PEM
         private-key headers (-----BEGIN ... PRIVATE KEY-----, case-insensitive).
  med  — a secret-looking assignment: an identifier like api_key/secret/token/
         password/access_key set to a value at least `min_token_length` characters
         long. Covers quoted literals (incl. quoted-key JSON) and unquoted env/yaml
         scalars. Likely, but uncertain, so it escalates rather than blocks.

Verdict (see references/gate-contract.md):
  any finding whose severity is in `fail_on` (default ["high"]) -> fail (exit 1)
  other findings only                                           -> escalate (exit 2)
  no findings                                                   -> pass (exit 0)
  no existing files to scan                                     -> skip (exit 3)

Config keys (policy.gates.secret-scan):
  min_token_length  min length of a value to flag a secret-looking assignment (default 16)
  allowlist         regexes; any line matching one is skipped entirely (placeholders, fixtures)
  fail_on           severities that hard-fail instead of escalating (default ["high"])
  patterns          extra detectors: [{name, regex, severity}] appended to the built-ins

Invalid user-supplied regexes (allowlist or patterns) are skipped with a stderr
diagnostic — a config typo never converts into a pipeline-wide internal error.
"""
import os
import re
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import gatelib  # noqa: E402

GATE, TIER = "secret-scan", 0

# High-confidence, unambiguous secret shapes. AWS keys are uppercase by
# definition (kept case-sensitive to avoid matching ordinary words); the PEM
# header is matched case-insensitively.
HIGH_PATTERNS = [
    ("aws-access-key-id", re.compile(r"AKIA[0-9A-Z]{16}"), "high"),
    ("private-key-header", re.compile(r"(?i)-----BEGIN[A-Z0-9 ]*PRIVATE KEY-----"), "high"),
]
# Identifiers that name a secret when assigned a long value.
SECRET_IDENT = r"(?:api[_-]?key|secret|token|password|passwd|access[_-]?key|auth[_-]?token|client[_-]?secret)"
# Optional quotes around the identifier handle quoted-key JSON ("api_key": "..").
# The value is either a quoted literal or an unquoted env/yaml scalar (no quotes,
# whitespace, comment, or call punctuation), measured against min_token_length.
ASSIGN_RE = re.compile(
    r"(?i)['\"]?\b" + SECRET_IDENT + r"\b['\"]?\s*(?:[:=]|=>)\s*"
    r"(?:['\"]([^'\"]+)['\"]|([^\s'\"#,;()]+))")


def is_binary(text):
    return "\x00" in text[:4096]


def compile_regexes(raw_list, kind):
    """Compile user regexes, skipping invalid ones with a diagnostic (never crash)."""
    out = []
    for p in raw_list or []:
        try:
            out.append(re.compile(p))
        except re.error as exc:
            sys.stderr.write("secret-scan: ignoring invalid %s regex %r: %s\n" % (kind, p, exc))
    return out


def main():
    _p, args = gatelib.parse_args()
    policy = gatelib.load_policy(args)
    opts = gatelib.gate_options(policy, GATE)
    root = args.context or "."

    min_len = int(opts.get("min_token_length", 16))
    fail_on = set(opts.get("fail_on", ["high"]))
    allowlist = compile_regexes(opts.get("allowlist", []), "allowlist")

    detectors = list(HIGH_PATTERNS)
    for extra in opts.get("patterns", []) or []:
        try:
            detectors.append((extra.get("name", "custom"),
                              re.compile(extra["regex"]),
                              extra.get("severity", "high")))
        except (re.error, KeyError, TypeError) as exc:
            sys.stderr.write("secret-scan: ignoring invalid custom pattern %r: %s\n" % (extra, exc))

    files = gatelib.expand_changed(args.changed, root)
    if not files:
        gatelib.emit(GATE, TIER, "skip", "no files to scan")

    findings = []
    scanned = 0
    for path in files:
        text = gatelib.read_text(path)
        if not text or is_binary(text):
            continue
        scanned += 1
        rel = os.path.relpath(path, root) if not os.path.isabs(path) else path
        for lineno, line in enumerate(text.splitlines(), start=1):
            if any(a.search(line) for a in allowlist):
                continue
            loc = "%s:%d" % (rel, lineno)
            matched_high = False
            for name, rx, sev in detectors:
                for _m in rx.finditer(line):
                    findings.append(gatelib.finding(
                        sev, loc, "Possible %s hard-coded in source." % name))
                    matched_high = matched_high or sev in fail_on
            if matched_high:
                continue
            m = ASSIGN_RE.search(line)
            if m:
                value = m.group(1) if m.group(1) is not None else m.group(2)
                if value and len(value) >= min_len:
                    findings.append(gatelib.finding(
                        "med", loc,
                        "Secret-looking assignment (%d-char value) — verify it is not a real credential." % len(value)))

    if not findings:
        gatelib.emit(GATE, TIER, "pass",
                     "no secrets found in %d file(s) scanned" % scanned, confidence=1.0)

    blocking = [f for f in findings if f["severity"] in fail_on]
    if blocking:
        gatelib.emit(GATE, TIER, "fail",
                     "%d hard-coded secret(s) found (%d blocking)" % (len(findings), len(blocking)),
                     findings, confidence=1.0)
    gatelib.emit(GATE, TIER, "escalate",
                 "%d possible secret(s) need review" % len(findings),
                 findings, confidence=0.6)


if __name__ == "__main__":
    try:
        main()
    except Exception as exc:  # noqa: BLE001
        gatelib.fail_internal(GATE, TIER, exc)
