{
  "_comment": "Copy to 'gates.config' at your repo root and adapt. This is the ONE place you point gates at your stack. A fresh install runs the language-agnostic gates immediately; every bring-your-own and heavy gate is disabled until you wire it up.",

  "policy": "policy.json",
  "fail_fast": true,

  "model": {
    "_comment": "Used only by the Tier 1 AI-judge gates. Anthropic Messages shape by default; set base_url to point at any compatible proxy. The API key is read from the env var NAMED here — never put a key in this file.",
    "endpoint": "https://api.anthropic.com/v1/messages",
    "base_url": null,
    "model": "claude-sonnet-4-6",
    "api_key_env": "ANTHROPIC_API_KEY",
    "max_tokens": 1024,
    "timeout_seconds": 60
  },

  "gates": [
    { "name": "spec-lint",        "tier": 0, "enabled": true,  "script": "spec-lint" },
    { "name": "trace-gate",       "tier": 0, "enabled": true,  "script": "trace-gate" },
    { "name": "redgreen-gate",    "tier": 0, "enabled": true,  "script": "redgreen-gate",
      "_note": "Set policy.gates.redgreen-gate.test_command to your suite. The runner expects GREEN; run with --expect red in Phase 2." },
    { "name": "intent-gate",      "tier": 0, "enabled": true,  "script": "intent-gate",
      "_note": "Kept JS/TS analyzer. For other languages, point this at your own contract-conformant analyzer via 'command'." },
    { "name": "secret-scan",      "tier": 0, "enabled": true,  "script": "secret-scan",
      "_note": "Kept, language-agnostic, key-free. Deterministically flags hard-coded secrets (AWS keys, private keys) as a hard fail and secret-looking assignments as an escalation. Tune patterns/allowlist in policy.gates.secret-scan." },
    { "name": "test-lock",        "tier": 0, "enabled": true,  "script": "test-lock",
      "_note": "Tamper evidence for the Judge's tests: verifies every locked test file is byte-identical since Phase 2 (the Judge runs 'test-lock --write' at Phase 2 exit to create TEST-LOCK.json). Skips harmlessly until a lock exists." },
    { "name": "oversight-integrity", "tier": 0, "enabled": true, "script": "oversight-integrity", "waivable": true,
      "_note": "Fails if the diff touches the referee's own machinery (gates.config, policy.json, PROVENANCE.*, TEST-LOCK.json). Waivable so a deliberate Operator config change escalates for sign-off instead of hard-stopping. Tune policy.gates.oversight-integrity." },
    { "name": "deps-gate",        "tier": 0, "enabled": true,  "script": "deps-gate",
      "_note": "Escalates when the diff adds a new dependency (package.json, requirements.txt, pyproject.toml, go.mod, Cargo.toml, Gemfile) — new supply-chain surface needs Operator sign-off. Skips outside a git work tree." },
    { "name": "separation-gate",  "tier": 0, "enabled": false, "script": "separation-gate",
      "_note": "Enable once you maintain a PROVENANCE manifest to enforce Author != Judge." },
    { "name": "flake-gate",       "tier": 0, "enabled": false, "script": "flake-gate",
      "_note": "Re-runs the suite N times to catch non-determinism. Reuses redgreen-gate.test_command unless you set policy.gates.flake-gate.test_command. Off by default — it runs the suite multiple times." },
    { "name": "eval-gate",        "tier": 0, "enabled": false, "script": "eval-gate",
      "_note": "Red/green for nondeterministic (LLM-app) code: runs policy.gates.eval-gate.eval_command N trials, holds pass rate (and optional mean score via score_regex) to a floor. BYO harness. Off by default — it runs your evals N times." },
    { "name": "diff-budget",      "tier": 0, "enabled": false, "script": "diff-budget", "waivable": true,
      "_note": "Phase 7 reviewability cap. Set policy.gates.diff-budget.max_lines/base_ref. A fail escalates (waivable) so a justified big change can proceed after a human looks." },

    { "name": "lint",             "tier": 0, "enabled": false,
      "command": ["./scripts/adapter", "--name", "lint", "--tier", "0", "--", "echo", "configure-your-linter"],
      "_note": "BYO. Wrap any pass/fail linter with adapter, or point at a tool that emits contract JSON." },
    { "name": "coverage",         "tier": 0, "enabled": false,
      "command": ["./scripts/adapter", "--name", "coverage", "--tier", "0", "--", "echo", "configure-coverage"],
      "_note": "BYO. e.g. adapter -- pytest --cov --cov-fail-under=80" },
    { "name": "mutation",         "tier": 0, "enabled": false,
      "command": ["./scripts/adapter", "--name", "mutation", "--tier", "0", "--", "echo", "configure-mutation"],
      "waivable": true,
      "_note": "BYO + EXPENSIVE. Point at your mutation tool. A failure escalates (waivable) instead of hard-stopping." },

    { "name": "semantic-test-judge", "tier": 1, "enabled": false, "script": "semantic-test-judge",
      "_note": "Needs model config above + the api_key_env to be set." },
    { "name": "fresh-eyes-review",   "tier": 1, "enabled": false, "script": "fresh-eyes-review",
      "_note": "Needs model config above + the api_key_env to be set." },
    { "name": "trajectory-judge",    "tier": 1, "enabled": false, "script": "trajectory-judge",
      "_note": "Audits HOW the code was produced: the model reads the Author's exported transcript (policy.gates.trajectory-judge.transcript_file) for cheat signals — intent to game, test tampering, hardcoded expectations, forbidden channels, oversight tampering, misreporting. Needs model config + a transcript file." }
  ]
}
