{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fofo-agentic-sdlc/policy.schema.json",
  "title": "FoFo Agentic SDLC policy",
  "description": "Per-gate behavior (thresholds, banned patterns, file conventions). Orchestration lives in gates.config, not here.",
  "type": "object",
  "properties": {
    "_comment": { "type": "string" },
    "gates": {
      "type": "object",
      "description": "Keyed by gate name. Each gate reads its own options from gates.<name>.",
      "properties": {
        "spec-lint": {
          "type": "object",
          "properties": {
            "spec_file": { "type": "string", "default": "REQUIREMENTS.md" },
            "id_pattern": { "type": "string", "description": "Regex matching a requirement ID.", "default": "REQ-\\d+" },
            "acceptance_label": { "type": "string", "default": "Acceptance" },
            "accept_ears": { "type": "boolean", "default": true, "description": "An EARS-format line (WHEN/IF/WHILE/WHERE ... SHALL) counts as an acceptance criterion even without the label." }
          },
          "additionalProperties": false
        },
        "trace-gate": {
          "type": "object",
          "properties": {
            "spec_file": { "type": "string", "default": "REQUIREMENTS.md" },
            "id_pattern": { "type": "string", "default": "REQ-\\d+" },
            "test_reqs": { "type": "string", "default": "TEST-REQS.yaml" },
            "test_glob": {
              "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }],
              "description": "Globs locating test files when none are in --changed."
            }
          },
          "additionalProperties": false
        },
        "redgreen-gate": {
          "type": "object",
          "properties": {
            "test_command": { "type": ["string", "null"], "description": "Shell command that runs the suite." },
            "red_for_reason": { "type": "array", "items": { "type": "string" }, "description": "Regexes that mark a 'wrong' red (load/collection error)." },
            "timeout_seconds": { "type": "integer", "minimum": 1, "default": 600 }
          },
          "additionalProperties": false
        },
        "flake-gate": {
          "type": "object",
          "properties": {
            "test_command": { "type": ["string", "null"], "description": "Shell command that runs the suite. Falls back to redgreen-gate.test_command." },
            "runs": { "type": "integer", "minimum": 2, "default": 3, "description": "How many times to run the suite to judge determinism." },
            "timeout_seconds": { "type": "integer", "minimum": 1, "default": 600 }
          },
          "additionalProperties": false
        },
        "diff-budget": {
          "type": "object",
          "properties": {
            "max_lines": { "type": "integer", "minimum": 1, "default": 400, "description": "Budget for added+deleted lines before the change is too big to review." },
            "base_ref": { "type": "string", "default": "HEAD", "description": "Git ref to diff against in git mode." },
            "count_mode": { "enum": ["auto", "git", "lines"], "default": "auto", "description": "git: numstat vs base_ref. lines: total line count of --changed. auto: git when in a work tree, else lines." },
            "on_exceed": { "enum": ["escalate", "fail"], "default": "escalate", "description": "Status emitted when over budget." }
          },
          "additionalProperties": false
        },
        "intent-gate": {
          "type": "object",
          "properties": {
            "test_launchers": { "type": "array", "items": { "type": "string" } },
            "assertion_roots": { "type": "array", "items": { "type": "string" } },
            "banned_mocks": { "type": "array", "items": { "type": "string" }, "description": "Regexes forbidden inside test bodies." },
            "allow_snapshot_only": { "type": "boolean", "default": false },
            "fail_on": {
              "type": "array",
              "items": { "enum": ["assertion-free", "trivial", "snapshot-only"] },
              "description": "Categories that are hard fails; others escalate."
            }
          },
          "additionalProperties": false
        },
        "separation-gate": {
          "type": "object",
          "properties": {
            "manifest": { "type": ["string", "null"], "description": "Path to PROVENANCE.yaml/.json." }
          },
          "additionalProperties": false
        },
        "test-lock": {
          "type": "object",
          "properties": {
            "lock_file": { "type": "string", "default": "TEST-LOCK.json", "description": "Lock manifest written by 'test-lock --write' at Phase 2 exit." },
            "test_glob": {
              "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }, { "type": "null" }],
              "description": "Globs selecting the test files to lock/verify when none are in --changed."
            }
          },
          "additionalProperties": false
        },
        "oversight-integrity": {
          "type": "object",
          "properties": {
            "protected": {
              "type": ["array", "null"], "items": { "type": "string" },
              "description": "fnmatch patterns for oversight files (replaces the default set: gates.config, policy.json, policy.schema.json, PROVENANCE.*, TEST-LOCK.json)."
            },
            "extra_protected": { "type": "array", "items": { "type": "string" }, "description": "Patterns appended to the protected set." },
            "base_ref": { "type": "string", "default": "HEAD", "description": "Git ref to diff against in git mode." },
            "on_touch": { "enum": ["fail", "escalate"], "default": "fail", "description": "Status emitted when an oversight file is touched." }
          },
          "additionalProperties": false
        },
        "deps-gate": {
          "type": "object",
          "properties": {
            "manifests": {
              "type": ["array", "null"], "items": { "type": "string" },
              "description": "Manifest basenames to diff (replaces the default set: package.json, requirements.txt, pyproject.toml, go.mod, Cargo.toml, Gemfile)."
            },
            "base_ref": { "type": "string", "default": "HEAD", "description": "Git ref to diff dependency sets against." },
            "on_new": { "enum": ["escalate", "fail"], "default": "escalate", "description": "Status emitted when a new dependency appears." }
          },
          "additionalProperties": false
        },
        "secret-scan": {
          "type": "object",
          "properties": {
            "min_token_length": { "type": "integer", "minimum": 1, "default": 16, "description": "Min length of a quoted literal to flag a secret-looking assignment." },
            "allowlist": { "type": "array", "items": { "type": "string" }, "description": "Regexes; any line matching one is skipped (placeholders, fixtures)." },
            "fail_on": { "type": "array", "items": { "enum": ["low", "med", "high"] }, "description": "Severities that hard-fail instead of escalating.", "default": ["high"] },
            "patterns": {
              "type": "array",
              "description": "Extra detectors appended to the built-ins.",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "regex": { "type": "string" },
                  "severity": { "enum": ["low", "med", "high"] }
                },
                "required": ["name", "regex"],
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "eval-gate": {
          "type": "object",
          "properties": {
            "eval_command": { "type": ["string", "null"], "description": "Shell command that runs ONE eval trial (BYO harness)." },
            "trials": { "type": "integer", "minimum": 1, "default": 3, "description": "How many times to run the eval command." },
            "min_pass_rate": { "type": "number", "minimum": 0, "maximum": 1, "default": 1.0, "description": "Floor for passed/total trials." },
            "score_regex": { "type": ["string", "null"], "description": "Regex with one float group matched against each trial's stdout (e.g. 'accuracy: ([0-9.]+)')." },
            "min_score": { "type": ["number", "null"], "description": "Floor for the mean extracted score across trials (requires score_regex)." },
            "timeout_seconds": { "type": "integer", "minimum": 1, "default": 600 },
            "on_fail": { "enum": ["fail", "escalate"], "default": "fail" }
          },
          "additionalProperties": false
        },
        "trajectory-judge": {
          "type": "object",
          "properties": {
            "transcript_file": { "type": "string", "default": "TRAJECTORY.md", "description": "The Author's exported working transcript." },
            "max_chars": { "type": "integer", "minimum": 1000, "default": 24000, "description": "Transcript budget sent to the model (head+tail kept when truncating)." },
            "escalate_below": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.6 }
          },
          "additionalProperties": false
        },
        "semantic-test-judge": {
          "type": "object",
          "properties": {
            "spec_file": { "type": "string", "default": "REQUIREMENTS.md" },
            "escalate_below": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.6 }
          },
          "additionalProperties": false
        },
        "fresh-eyes-review": {
          "type": "object",
          "properties": {
            "spec_file": { "type": "string", "default": "REQUIREMENTS.md" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
