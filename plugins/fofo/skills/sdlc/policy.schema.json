{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fofo-agentic-sdlc/policy.schema.json",
  "title": "FoFo Agentic SDLC policy",
  "description": "Per-gate behavior (thresholds, banned patterns, file conventions). Orchestration lives in gates.config, not here.",
  "type": "object",
  "properties": {
    "_comment": { "type": "string" },
    "gates": {
      "type": "object",
      "description": "Keyed by gate name. Each gate reads its own options from gates.<name>.",
      "properties": {
        "spec-lint": {
          "type": "object",
          "properties": {
            "spec_file": { "type": "string", "default": "REQUIREMENTS.md" },
            "id_pattern": { "type": "string", "description": "Regex matching a requirement ID.", "default": "REQ-\\d+" },
            "acceptance_label": { "type": "string", "default": "Acceptance" }
          },
          "additionalProperties": false
        },
        "trace-gate": {
          "type": "object",
          "properties": {
            "spec_file": { "type": "string", "default": "REQUIREMENTS.md" },
            "id_pattern": { "type": "string", "default": "REQ-\\d+" },
            "test_reqs": { "type": "string", "default": "TEST-REQS.yaml" },
            "test_glob": {
              "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }],
              "description": "Globs locating test files when none are in --changed."
            }
          },
          "additionalProperties": false
        },
        "redgreen-gate": {
          "type": "object",
          "properties": {
            "test_command": { "type": ["string", "null"], "description": "Shell command that runs the suite." },
            "red_for_reason": { "type": "array", "items": { "type": "string" }, "description": "Regexes that mark a 'wrong' red (load/collection error)." },
            "timeout_seconds": { "type": "integer", "minimum": 1, "default": 600 }
          },
          "additionalProperties": false
        },
        "flake-gate": {
          "type": "object",
          "properties": {
            "test_command": { "type": ["string", "null"], "description": "Shell command that runs the suite. Falls back to redgreen-gate.test_command." },
            "runs": { "type": "integer", "minimum": 2, "default": 3, "description": "How many times to run the suite to judge determinism." },
            "timeout_seconds": { "type": "integer", "minimum": 1, "default": 600 }
          },
          "additionalProperties": false
        },
        "diff-budget": {
          "type": "object",
          "properties": {
            "max_lines": { "type": "integer", "minimum": 1, "default": 400, "description": "Budget for added+deleted lines before the change is too big to review." },
            "base_ref": { "type": "string", "default": "HEAD", "description": "Git ref to diff against in git mode." },
            "count_mode": { "enum": ["auto", "git", "lines"], "default": "auto", "description": "git: numstat vs base_ref. lines: total line count of --changed. auto: git when in a work tree, else lines." },
            "on_exceed": { "enum": ["escalate", "fail"], "default": "escalate", "description": "Status emitted when over budget." }
          },
          "additionalProperties": false
        },
        "intent-gate": {
          "type": "object",
          "properties": {
            "test_launchers": { "type": "array", "items": { "type": "string" } },
            "assertion_roots": { "type": "array", "items": { "type": "string" } },
            "banned_mocks": { "type": "array", "items": { "type": "string" }, "description": "Regexes forbidden inside test bodies." },
            "allow_snapshot_only": { "type": "boolean", "default": false },
            "fail_on": {
              "type": "array",
              "items": { "enum": ["assertion-free", "trivial", "snapshot-only"] },
              "description": "Categories that are hard fails; others escalate."
            }
          },
          "additionalProperties": false
        },
        "separation-gate": {
          "type": "object",
          "properties": {
            "manifest": { "type": ["string", "null"], "description": "Path to PROVENANCE.yaml/.json." }
          },
          "additionalProperties": false
        },
        "secret-scan": {
          "type": "object",
          "properties": {
            "min_token_length": { "type": "integer", "minimum": 1, "default": 16, "description": "Min length of a quoted literal to flag a secret-looking assignment." },
            "allowlist": { "type": "array", "items": { "type": "string" }, "description": "Regexes; any line matching one is skipped (placeholders, fixtures)." },
            "fail_on": { "type": "array", "items": { "enum": ["low", "med", "high"] }, "description": "Severities that hard-fail instead of escalating.", "default": ["high"] },
            "patterns": {
              "type": "array",
              "description": "Extra detectors appended to the built-ins.",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "regex": { "type": "string" },
                  "severity": { "enum": ["low", "med", "high"] }
                },
                "required": ["name", "regex"],
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "semantic-test-judge": {
          "type": "object",
          "properties": {
            "spec_file": { "type": "string", "default": "REQUIREMENTS.md" },
            "escalate_below": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.6 }
          },
          "additionalProperties": false
        },
        "fresh-eyes-review": {
          "type": "object",
          "properties": {
            "spec_file": { "type": "string", "default": "REQUIREMENTS.md" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
